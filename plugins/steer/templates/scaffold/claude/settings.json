{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh search issues:*)",
      "Bash(gh auth status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh repo view:*)",
      "Bash(gh label list:*)",
      "Bash(mise tasks:*)",
      "Bash(mise install:*)",
      "Bash(mise lock:*)",
      "Bash(mise run check:*)",
      "Bash(mise run ci:*)",
      "Bash(mise run dev:*)",
      "mcp__github__create_issue",
      "mcp__github__update_issue",
      "mcp__github__add_issue_comment",
      "mcp__github__get_issue",
      "mcp__github__list_issues",
      "mcp__github__search_issues",
      "mcp__github__add_sub_issue"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(git push --set-upstream origin:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ],
    "deny": [
      "Bash(git push*--force*)",
      "Bash(git push*--delete*)",
      "Bash(git push*--mirror*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit*--no-gpg-sign*)",
      "Bash(git add -f*)",
      "Bash(git add --force*)",
      "Bash(git add*.env)"
    ]
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "steer@e22-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "e22-plugins": {
      "source": {
        "source": "github",
        "repo": "element22llc/e22-plugins"
      },
      "autoUpdate": true
    }
  }
}
