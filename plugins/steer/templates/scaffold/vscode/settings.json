{
  // Shared workspace defaults. Wires Biome (the repo's lint+format tool) in as
  // the formatter so format-on-save matches `pnpm format` / CI. Per-user
  // overrides belong in .vscode/settings.local.json (gitignored), not here.
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "quickfix.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "[javascript][javascriptreact][typescript][typescriptreact][json][jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  // GitHub Copilot picks up the steer engineering standards from
  // .github/copilot-instructions.md and the per-skill .github/prompts/*.prompt.md
  // slash-commands. Both are default-on in recent VS Code; set them explicitly so
  // the standards load regardless of a teammate's defaults. Remove if Copilot is unused.
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "chat.promptFiles": true
}
