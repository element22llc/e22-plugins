# Copy to infra/.env (gitignored) and fill in. mise loads it automatically
# (`_.file = ".env"` in mise.toml), so the cf:* tasks pick these up.
#
# Cloudflare credentials for the cf:* tasks.
# API token scope:
#   - Pages deploy (cf:check / cf:deploy:preview):  Account → Cloudflare Pages → Edit
#   - Access setup  (cf:access:plan / :apply):      Account → Access: Apps and Policies → Edit
#                                                   + Account → Access: Identity Providers → Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# GitHub OAuth app for the Cloudflare Access GitHub login (cf:access:* — managed in
# live/access). Create the OAuth app at github.com → Settings → Developer settings →
# OAuth Apps, with callback https://<team>.cloudflareaccess.com/cdn-cgi/access/callback.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Optional: override any AWS env from mise.toml here (e.g. AWS_EC2_METADATA_DISABLED).
