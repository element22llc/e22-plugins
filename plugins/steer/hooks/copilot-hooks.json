{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "bash": "STEER_HOOK_TARGET=copilot sh \"${CLAUDE_PLUGIN_ROOT}/hooks/check-version-pins.sh\" || true",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "Bash",
        "bash": "STEER_HOOK_TARGET=copilot sh \"${CLAUDE_PLUGIN_ROOT}/hooks/check-bash-actions.sh\" || true",
        "timeoutSec": 10
      }
    ]
  }
}
