# Local config — variable NAMES only, no real secrets. Committed as the
# documented list of what the app reads. Copy to a git-ignored `.env` (or
# `.env.local`) and fill in real values there; deployed secrets live in AWS
# Secrets Manager, never here. Compose reads `.env` automatically.
#
# Baseline matches the default stack (PostgreSQL via compose.yaml). Add the
# product's own vars on fork (/steer:init); delete the DB vars if it has no
# backing services.

# Host port for the Postgres container (compose.yaml binds "${POSTGRES_PORT:-5432}:5432").
# Running several DIFFERENT products at once? They all default to 5432 and collide
# on `docker compose up`. Set a distinct port here (e.g. 5433) and mirror it in
# DATABASE_URL below.
#
# Parallel worktrees of the SAME repo need no edit here: mise sources
# scripts/worktree-env.sh, which exports a per-worktree POSTGRES_PORT (and
# DATABASE_URL) that wins over these values for anything run via `mise run …`.
# The primary checkout keeps 5432. Only override here for the cross-product case.
POSTGRES_PORT=5432

# App connection string. The host port MUST match POSTGRES_PORT above.
DATABASE_URL=postgresql://app:app@localhost:5432/app  # update 5432 if you changed POSTGRES_PORT
