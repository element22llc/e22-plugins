# Copy to infra/.env (gitignored) and fill in. mise loads it automatically
# (`_.file = ".env"` in mise.toml), so the cf:* tasks pick these up.
#
# Cloudflare credentials for `mise run cf:check` / `cf:deploy:preview` (wrangler).
# API token scoped to: Account → Cloudflare Pages → Edit.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: override any AWS env from mise.toml here (e.g. AWS_EC2_METADATA_DISABLED).
