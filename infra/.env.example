# Copy to infra/.env (gitignored) and fill in. mise loads it automatically
# (`_.file = ".env"` in mise.toml), so the cf:* tasks pick these up.
#
# Cloudflare credentials for the cf:* tasks.
# API token scope (Account-level permission groups):
#   - Pages deploy (cf:check / cf:deploy:preview):  Cloudflare Pages → Edit
#   - Access setup  (cf:access:plan / :apply):      Access: Apps and Policies → Edit
# Note: enabling Access itself is a one-time dashboard step (see README runbook);
# the token cannot bootstrap it. Login uses Cloudflare's built-in One-time PIN, so
# there is no identity-provider OAuth app to register and no extra token scope.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: override any AWS env from mise.toml here (e.g. AWS_EC2_METADATA_DISABLED).
